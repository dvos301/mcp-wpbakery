# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Build artifacts — ignore the dist dir, but keep the built plugin zip tracked
# so it's visible/downloadable straight from the repo file tree.
dist/*
!dist/mcp-wpbakery.zip

# Secrets: client configs hold app passwords — never commit them.
clients/*.json
!clients/example.json

# Scratch / one-offs
server/_*.py
*.log
.DS_Store
